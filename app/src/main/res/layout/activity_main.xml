<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="50dp"
    android:orientation="vertical">
    <com.example.android_project.custom.widget.layout.SettingBar
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:bar_startText="@string/bar_setting">
    </com.example.android_project.custom.widget.layout.SettingBar>

    <com.example.android_project.custom.widget.layout.SettingBar
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:bar_startText="@string/cb_name1">
    </com.example.android_project.custom.widget.layout.SettingBar>

    <EditText
        android:layout_height="wrap_content"
        android:layout_width="match_parent"
        android:background="#a1a9ba"
        android:inputType="text"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <CheckBox
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cb_name1"/>
        <CheckBox
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cb_name2"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/app_name"/>

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/bt_save"/>
    <Space
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/white"
        app:itemTextColor="@color/color_menu_navigation"
        app:itemIconTint="@color/color_menu_navigation"
        app:menu="@menu/menu_navigation" />
</LinearLayout>
